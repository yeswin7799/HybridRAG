import numpy as np
import pandas as pd
import torch
from sentence_transformers import SentenceTransformer

# Import faiss — it's already on Kaggle, just needs importing
try:
    import faiss
    print("FAISS imported successfully!")
    print("FAISS version:", faiss.__version__)
except:
    get_ipython().getoutput("pip install faiss-cpu -q")
    import faiss
    print("FAISS installed and imported!")

# Check GPU
print("\nGPU available:", torch.cuda.is_available())
print("GPU name:", torch.cuda.get_device_name(0))

# Load our cleaned data
df = pd.read_csv('cleaned_complaints.csv')
print(f"\nLoaded {len(df)} complaints")
print("Columns:", df.columns.tolist())


# WHY: We load the sentence transformer model onto our GPU.
# 'all-MiniLM-L6-v2' is a small but powerful model that:
# → converts any text into 384 numbers (called a vector/embedding)
# → similar meaning = similar numbers
# → runs fast on our T4 GPU
# It will download ~90MB the first time, then cache it.

device = 'cuda' if torch.cuda.is_available() else 'cpu'
print(f"Using device: {device}")

model = SentenceTransformer('all-MiniLM-L6-v2', device=device)

# Test it on one sentence so you can see what an embedding looks like
test_embedding = model.encode("my credit card bill is wrong")
print(f"\nEmbedding shape: {test_embedding.shape}")
print(f"First 10 numbers: {test_embedding[:10].round(4)}")
print("\nModel loaded successfully!")


# WHY: We now run every single complaint through the model.
# Each complaint becomes 384 numbers capturing its meaning.
# batch_size=256 means we process 256 complaints at a time on the GPU
# show_progress_bar=True so we can see how fast it's going.
# This should take about 3-5 minutes on T4.

print("Encoding all complaints... (this takes ~3-5 mins on T4)")

complaints = df['Consumer complaint narrative'].tolist()

embeddings = model.encode(
    complaints,
    batch_size=256,
    show_progress_bar=True,
    device=device,
    convert_to_numpy=True
)

print(f"\nDone!")
print(f"Embeddings shape: {embeddings.shape}")
print(f"→ {embeddings.shape[0]} complaints, each converted to {embeddings.shape[1]} numbers")


# WHY: Now we load all those embeddings into FAISS so it can
# search through them super fast.
#
# IndexFlatIP = "Flat Index using Inner Product"
# Inner Product on normalized vectors = cosine similarity
# (cosine similarity measures the angle between two vectors —
#  angle close to 0 = very similar meaning)
#
# faiss.normalize_L2() scales all vectors to length 1
# so the math works correctly for cosine similarity.

dimension = embeddings.shape[1]  # 384

# Normalize embeddings for cosine similarity
faiss.normalize_L2(embeddings)

# Build the index
index = faiss.IndexFlatIP(dimension)
index.add(embeddings)

print(f"FAISS index built!")
print(f"Total vectors stored in index: {index.ntotal}")


# WHY: Before moving on we always test that our search actually works.
# We give it a real complaint and see if it finds similar ones.
# This is called a sanity check.

def search_similar(query, top_k=3):
    # Step 1: Convert query text to embedding
    query_embedding = model.encode([query], convert_to_numpy=True)
    
    # Step 2: Normalize it (same as we did for stored embeddings)
    faiss.normalize_L2(query_embedding)
    
    # Step 3: Search FAISS for top_k most similar
    scores, indices = index.search(query_embedding, top_k)
    
    print(f"Query: '{query}'\n")
    print("Top similar complaints found:\n")
    for i, (score, idx) in enumerate(zip(scores[0], indices[0])):
        print(f"Result {i+1} | Similarity: {score:.4f} | Category: {df['Product'][idx]}")
        print(f"Text: {df['Consumer complaint narrative'][idx][:150]}...")
        print()

# Test with two different queries
search_similar("my credit card payment was charged twice")
print("=" * 60)
search_similar("the bank wrongly reported me to credit bureau")


# WHY: Building embeddings took ~5 minutes. We save the FAISS index
# and embeddings to disk so next time we just load them instantly
# instead of rebuilding from scratch.

import pickle

# Save FAISS index
faiss.write_index(index, 'faiss_index.bin')

# Save embeddings array
np.save('embeddings.npy', embeddings)

# Save the complaints list separately for easy access
with open('complaints_list.pkl', 'wb') as f:
    pickle.dump(complaints, f)

print("Saved files:")
print("  → faiss_index.bin   (the searchable index)")
print("  → embeddings.npy    (all 49,949 embeddings)")
print("  → complaints_list.pkl (original text)")
print("\nStep 2 — Semantic Search is 100% complete! ✅")


from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity
import scipy.sparse
import pickle

# WHY: TfidfVectorizer converts all complaints into a matrix of
# TF-IDF scores. Each row = one complaint. Each column = one word.
# max_features=50000 means we track the 50,000 most important words.
# min_df=2 means ignore words that appear in only 1 complaint (typos etc.)
# max_df=0.95 means ignore words that appear in 95%+ of complaints (too common)

print("Building TF-IDF index...")

tfidf = TfidfVectorizer(
    max_features=50000,
    min_df=2,
    max_df=0.95,
    ngram_range=(1, 2)  # captures both single words AND two-word phrases
)

tfidf_matrix = tfidf.fit_transform(complaints)

print(f"TF-IDF matrix shape: {tfidf_matrix.shape}")
print(f"→ {tfidf_matrix.shape[0]} complaints")
print(f"→ {tfidf_matrix.shape[1]} unique words/phrases tracked")


# WHY: Same sanity check as we did for FAISS.
# We verify keyword search finds relevant results before moving on.

def search_tfidf(query, top_k=3):
    # Convert query to TF-IDF vector
    query_vec = tfidf.transform([query])
    
    # Compute similarity against all complaints
    scores = cosine_similarity(query_vec, tfidf_matrix).flatten()
    
    # Get top_k highest scoring indices
    top_indices = scores.argsort()[-top_k:][::-1]
    
    print(f"Query: '{query}'\n")
    print("Top keyword matches found:\n")
    for i, idx in enumerate(top_indices):
        print(f"Result {i+1} | Score: {scores[idx]:.4f} | Category: {df['Product'][idx]}")
        print(f"Text: {complaints[idx][:150]}...")
        print()

# Test with same queries as FAISS so we can compare
search_tfidf("my credit card payment was charged twice")
print("=" * 60)
search_tfidf("the bank wrongly reported me to credit bureau")


# WHY: Save both the vectorizer (which knows all the words)
# and the matrix (the actual scores) so we don't rebuild next time.

with open('tfidf_vectorizer.pkl', 'wb') as f:
    pickle.dump(tfidf, f)

scipy.sparse.save_npz('tfidf_matrix.npz', tfidf_matrix)

print("Saved files:")
print("  → tfidf_vectorizer.pkl  (the vocabulary + weights)")
print("  → tfidf_matrix.npz      (the searchable matrix)")
print("\nStep 3 — Keyword Search complete! ✅")


