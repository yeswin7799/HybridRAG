import pandas as pd

df = pd.read_csv('/kaggle/input/datasets/selener/consumer-complaint-database/rows.csv', low_memory=False)
print("Shape:", df.shape)
print("\nColumns:", df.columns.tolist())
print("\nFirst row:")
df.head(1)


print(df.columns.tolist())


# WHY: Drop all columns we don't need, keep only text + label
df_clean = df[['Consumer complaint narrative', 'Product']].copy()

print("Original shape:", df.shape)
print("Cleaned shape:", df_clean.shape)


# WHY: Rows with no complaint text are useless for our search system
df_clean = df_clean.dropna(subset=['Consumer complaint narrative'])

print("After removing empty complaints:", df_clean.shape)
print("\nUnique product categories:")
print(df_clean['Product'].value_counts())


# WHY: 50k rows gives our retrieval system a rich knowledge base.
# With T4 GPU, sentence-transformers can encode this in ~5 minutes.
# random_state=42 means you get the same sample every time you run it.

df_sample = df_clean.sample(n=50000, random_state=42)
df_sample = df_sample.reset_index(drop=True)

print("Sample shape:", df_sample.shape)
print("\nCategory distribution:")
print(df_sample['Product'].value_counts())


# WHY: We map old names → new standardized names so the model
# sees consistent labels. This is called label consolidation.

category_mapping = {
    'Credit reporting, credit repair services, or other personal consumer reports': 'Credit reporting',
    'Credit card or prepaid card': 'Credit card',
    'Payday loan, title loan, or personal loan': 'Payday loan',
    'Money transfer, virtual currency, or money service': 'Money transfers',
    'Prepaid card': 'Credit card',
    'Virtual currency': 'Money transfers',
}

df_sample['Product'] = df_sample['Product'].replace(category_mapping)

print("Cleaned category distribution:")
print(df_sample['Product'].value_counts())
print("\nTotal unique categories:", df_sample['Product'].nunique())


# WHY: 'Other financial service' has only 38 rows.
# That's not enough for our system to learn anything meaningful from.
# We keep only categories with at least 200 complaints.

min_count = 200
valid_categories = df_sample['Product'].value_counts()
valid_categories = valid_categories[valid_categories >= 200].index

df_sample = df_sample[df_sample['Product'].isin(valid_categories)]
df_sample = df_sample.reset_index(drop=True)

print("Final shape:", df_sample.shape)
print("\nFinal categories:")
print(df_sample['Product'].value_counts())


# WHY: Always look at your actual data, not just numbers.
# This lets you see if the text looks reasonable before building anything on top of it.

print("=== Sample complaints ===\n")
for i in range(3):
    print(f"Category : {df_sample['Product'][i]}")
    print(f"Complaint: {df_sample['Consumer complaint narrative'][i][:200]}...")
    print("-" * 60)


# WHY: Some rows contain form placeholder text, not real complaints.
# These would confuse our search system. We filter them out by
# checking if the complaint contains common template phrases.

junk_phrases = [
    'what happened describe',
    'describe what happened',
    'what happened so we can understand'
]

def is_junk(text):
    text_lower = text.lower()
    return any(phrase in text_lower for phrase in junk_phrases)

before = len(df_sample)
df_sample = df_sample[~df_sample['Consumer complaint narrative'].apply(is_junk)]
df_sample = df_sample.reset_index(drop=True)

print(f"Removed {before - len(df_sample)} junk complaints")
print(f"Final clean shape: {df_sample.shape}")


# WHY: We lowercase everything and strip extra spaces.
# "MORTGAGE" and "mortgage" are the same word — we don't want
# our model treating them as different. XXXX tokens we leave alone
# because they appear consistently and carry meaning (redacted info).

df_sample['Consumer complaint narrative'] = (
    df_sample['Consumer complaint narrative']
    .str.lower()
    .str.strip()
)

print("Text cleaning done!")
print("\nSample after cleaning:")
print(df_sample['Consumer complaint narrative'][0][:300])


# WHY: We save our cleaned data to a file so we don't have to
# redo all this cleaning every time we restart the notebook.
# Think of it as saving your game progress.

df_sample.to_csv('cleaned_complaints.csv', index=False)

print("Saved to cleaned_complaints.csv")
print(f"Final dataset: {df_sample.shape[0]} complaints across {df_sample['Product'].nunique()} categories")
print("\nFinal category counts:")
print(df_sample['Product'].value_counts())


